#!/bin/sh
# burrow — delegate work to sub-agents via new Burrow terminal tabs.
#
#   burrow spawn [--token T] [--cwd DIR] <command...>
#       Open a new terminal tab (in the current project) running <command>.
#       --token T   attach an id so you can `burrow wait T` for the result.
#       --cwd DIR   run the new tab in DIR instead of the current project dir.
#
#   burrow wait <token> [--timeout SECONDS]
#       Block until the sub-agent launched with that --token finishes its turn,
#       then print its final message to stdout. Exits 1 on timeout.
#
#   burrow capture <token>          (internal — invoked by a Claude Stop hook)
#       Reads a Stop-hook JSON from stdin and writes the sub-agent's last
#       message into the result file that `burrow wait` is watching.
#
# Transport is FILE-BASED (no tty, no socket): `spawn` drops a request dir under
# $BURROW_SESSION_DIR/requests/ which Burrow polls and turns into a new tab; the
# new tab's result comes back through $BURROW_SESSION_DIR/<token>.{result,done}.
# This works from Claude's Bash tool / hooks, which have no controlling tty.
#
# Sub-agents run INTERACTIVELY on your subscription (plain `claude`, never -p).

sub="$1"
[ -n "$sub" ] || { echo "usage: burrow spawn|collect|wait|sessions|status|hook|notify <args>" >&2; exit 1; }
shift

case "$sub" in
  spawn)
    token=""; cwd=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --token) token="$2"; shift 2 ;;
        --cwd)   cwd="$2";   shift 2 ;;
        --)      shift; break ;;
        -*)      echo "burrow spawn: unknown flag $1" >&2; exit 1 ;;
        *)       break ;;
      esac
    done
    [ -n "$1" ] || { echo "burrow spawn: no command given" >&2; exit 1; }

    # Rebuild the command as a shell line that re-parses correctly when typed
    # into the new tab. The program name stays bare (so XTerm's `claude` check
    # still matches); every remaining arg is single-quoted to preserve spaces,
    # quotes and newlines — e.g.  claude 'say hi to the user'.
    prog="$1"; shift
    fullcmd="$prog"
    for a in "$@"; do
      esc=$(printf '%s' "$a" | sed "s/'/'\\\\''/g")
      fullcmd="$fullcmd '$esc'"
    done

    reqdir="${BURROW_SESSION_DIR:?burrow: BURROW_SESSION_DIR unset — run inside Burrow}/requests"
    mkdir -p "$reqdir" || { echo "burrow: cannot create $reqdir" >&2; exit 1; }
    ws="${BURROW_CWD:-$PWD}"          # workspace this tab belongs to (routing key)
    newcwd="${cwd:-$ws}"             # where the new tab should open

    # Each field is its own raw file (no escaping needed). The `ready` marker is
    # written LAST so Burrow never reads a half-written request.
    d=$(mktemp -d "$reqdir/req.XXXXXX") || { echo "burrow: mktemp failed" >&2; exit 1; }
    printf '%s' "$fullcmd" > "$d/cmd"
    printf '%s' "$token"  > "$d/token"
    printf '%s' "$newcwd" > "$d/cwd"
    printf '%s' "$ws"     > "$d/ws"
    : > "$d/ready"

    # Soft concurrency limit (per workspace), surfaced for the agent's benefit.
    # NOT enforced here — the /burrow skill is told to respect it. Configurable in
    # Burrow Settings, published to this file (default 3 when absent).
    limit=3
    [ -n "$BURROW_HOME_DIR" ] && [ -f "$BURROW_HOME_DIR/max_agents" ] && \
      limit=$(cat "$BURROW_HOME_DIR/max_agents" 2>/dev/null)
    if [ -n "$token" ]; then
      echo "burrow: spawned sub-agent (token=$token) — fire-and-forget; later 'burrow collect $token' for its result (soft limit ${limit}/ws)" >&2
    else
      echo "burrow: spawned a new tab (soft limit ${limit} sub-agents/ws)" >&2
    fi
    exit 0
    ;;

  wait)
    token="$1"; [ $# -gt 0 ] && shift
    [ -n "$token" ] || { echo "burrow wait: no token given" >&2; exit 1; }
    timeout=0
    while [ $# -gt 0 ]; do
      case "$1" in
        --timeout) timeout="$2"; shift 2 ;;
        *)         shift ;;
      esac
    done
    dir="${BURROW_SESSION_DIR:?burrow: BURROW_SESSION_DIR unset — run inside Burrow}"
    done_f="$dir/$token.done"; res_f="$dir/$token.result"
    waited=0
    while [ ! -f "$done_f" ]; do
      sleep 1
      waited=$((waited + 1))
      if [ "$timeout" -gt 0 ] && [ "$waited" -ge "$timeout" ]; then
        echo "burrow wait: timed out after ${timeout}s (token=$token)" >&2
        exit 1
      fi
    done
    [ -f "$res_f" ] && cat "$res_f"
    exit 0
    ;;

  status)
    # burrow status <running|waiting|done>
    # Report this tab's agent state to Burrow's hook server. Any agent can call
    # this from a hook/notify program. Needs BURROW_PTY_ID + BURROW_HOOK_PORT
    # (exported into every Burrow PTY). No-op outside Burrow.
    state="$1"
    [ -n "$state" ] || { echo "burrow status: no state (running|waiting|done)" >&2; exit 1; }
    [ -n "$BURROW_PTY_ID" ] || exit 0
    # Port: the LIVE hook.port file is authoritative — the app rewrites it every
    # launch with the current (random) server port, and there is only ever one
    # running app. BURROW_HOOK_PORT is baked into the PTY env at creation, so a PTY
    # that survived an app restart (reattached from the daemon) carries a STALE
    # port; trusting it POSTs to a dead port and the status dot never updates.
    # So: file first, env only as a fallback when the file is missing.
    port=""
    [ -n "$BURROW_HOME_DIR" ] && [ -f "$BURROW_HOME_DIR/hook.port" ] && \
      port=$(cat "$BURROW_HOME_DIR/hook.port" 2>/dev/null)
    [ -z "$port" ] && port="$BURROW_HOOK_PORT"
    [ -n "$port" ] || exit 0
    curl -sf -X POST "http://127.0.0.1:$port/hook" \
      -H 'Content-Type: application/json' \
      -d "{\"ptyId\":$BURROW_PTY_ID,\"state\":\"$state\"}" >/dev/null 2>&1 || true
    exit 0
    ;;

  hook)
    # burrow hook   (internal — invoked by globally-installed Claude/Codex hooks)
    # Reads the hook JSON on stdin, maps hook_event_name → a Burrow state, forwards
    # via `burrow status`. No-op outside Burrow (BURROW_PTY_ID unset). Best-effort
    # string parse, no jq/node needed.
    [ -n "$BURROW_PTY_ID" ] || exit 0
    json=$(cat)
    ev=$(printf '%s' "$json" | sed -n 's/.*"hook_event_name"[ ]*:[ ]*"\([^"]*\)".*/\1/p')
    case "$ev" in
      UserPromptSubmit|PreToolUse|PostToolUse) state=running ;;
      Notification)
        # `Notification` is ambiguous: Claude fires it BOTH for a permission
        # prompt (genuinely waiting on the user) AND ~60s after a turn ends, idle
        # at the prompt ("Claude is waiting for your input"). The idle ping is NOT
        # "blocked on me" — the turn is already over — so mapping it to `waiting`
        # (blue) made finished agents look stuck-blue. Disambiguate by message:
        # an idle ping means done; anything else (permission, etc.) means waiting.
        msg=$(printf '%s' "$json" | sed -n 's/.*"message"[ ]*:[ ]*"\([^"]*\)".*/\1/p')
        case "$msg" in
          *waiting\ for\ your\ input*) state=done ;;
          *)                          state=waiting ;;
        esac ;;
      PermissionRequest)            state=waiting ;;
      Stop|SessionEnd)              state=done ;;
      *)                            exit 0 ;;
    esac
    burrow status "$state"
    exit 0
    ;;

  notify)
    # burrow notify '<json>'   (internal — invoked by Codex's `notify` program)
    # Codex passes a single JSON arg describing a lifecycle event. Map its "type"
    # to a Burrow state and forward via `burrow status`. Best-effort string parse
    # (no jq/node dependency — Codex users may not have node).
    json="$1"
    [ -n "$json" ] || exit 0
    type=$(printf '%s' "$json" | sed -n 's/.*"type"[ ]*:[ ]*"\([^"]*\)".*/\1/p')
    case "$type" in
      task_started|task-started|turn_started)              state=running ;;
      agent-turn-complete|task_complete|turn_complete)     state=done ;;
      *approval*|*approval_request|request_user_input)     state=waiting ;;
      *)                                                   exit 0 ;;
    esac
    burrow status "$state"
    exit 0
    ;;

  capture)
    token="$1"
    dir="${BURROW_SESSION_DIR:?}"
    [ -n "$token" ] || exit 0
    # Parse Stop-hook JSON (stdin) → transcript_path → last assistant text,
    # write <token>.result then <token>.done. Node is always present (Claude
    # Code requires it), so we don't depend on jq.
    BURROW_DIR="$dir" BURROW_TOKEN="$token" node -e '
      let raw = "";
      process.stdin.on("data", d => raw += d).on("end", () => {
        const fs = require("fs"), path = require("path");
        const dir = process.env.BURROW_DIR, tok = process.env.BURROW_TOKEN;
        let text = "";
        try {
          const tp = JSON.parse(raw).transcript_path;
          if (tp && fs.existsSync(tp)) {
            const lines = fs.readFileSync(tp, "utf8").split("\n").filter(Boolean);
            for (let i = lines.length - 1; i >= 0; i--) {
              let o; try { o = JSON.parse(lines[i]); } catch { continue; }
              const m = o.message || o;
              if ((o.type === "assistant" || m.role === "assistant") && m.content) {
                text = (Array.isArray(m.content) ? m.content : [m.content])
                  .map(c => typeof c === "string" ? c : (c && c.type === "text" ? c.text : ""))
                  .join("");
                if (text.trim()) break;
              }
            }
          }
        } catch {}
        try { fs.writeFileSync(path.join(dir, tok + ".result"), text); } catch {}
        try { fs.writeFileSync(path.join(dir, tok + ".done"), ""); } catch {}
      });
    '
    # Also report the turn as done to the status server. A spawned sub-agent runs
    # with a per-launch `--settings` whose Stop hook is THIS capture; Claude Code
    # gives that file precedence and does NOT also run the globally-installed
    # `burrow hook` Stop (same event), so without this the sub-agent's status dot
    # would stay stuck orange after it finishes. (No-op outside Burrow.)
    burrow status done
    exit 0
    ;;

  collect)
    # burrow collect [token...]   — NON-BLOCKING recap of finished sub-agents.
    # Prints the result of every given token that has finished (its `<token>.done`
    # exists), then CONSUMES it (deletes .done + .result) so a later collect only
    # returns newly-finished ones. With no tokens, collects every finished result
    # in the session. Never blocks — the spawning agent calls this whenever it
    # wants a recap, without waiting on the sub-agents.
    dir="${BURROW_SESSION_DIR:?burrow: BURROW_SESSION_DIR unset — run inside Burrow}"
    if [ $# -eq 0 ]; then
      for df in "$dir"/*.done; do
        [ -f "$df" ] || continue
        b=$(basename "$df"); set -- "$@" "${b%.done}"
      done
    fi
    any=0; pending=""
    for tok in "$@"; do
      if [ -f "$dir/$tok.done" ]; then
        any=1
        echo "=== $tok ==="
        [ -f "$dir/$tok.result" ] && cat "$dir/$tok.result"
        echo
        rm -f "$dir/$tok.done" "$dir/$tok.result"
      else
        pending="$pending $tok"
      fi
    done
    [ "$any" = 0 ] && echo "burrow collect: nothing finished yet" >&2
    [ -n "$pending" ] && echo "burrow collect: still running:$pending" >&2
    exit 0
    ;;

  sessions)
    # burrow sessions [--count]   — list live PTY sessions the daemon is holding.
    # Talks the daemon's newline-JSON protocol over its Unix socket (Auth then
    # ListSessions). Reads socket path + auth token from BURROW_HOME_DIR.
    home="${BURROW_HOME_DIR:?burrow: BURROW_HOME_DIR unset — run inside Burrow}"
    count_only=0
    [ "$1" = "--count" ] && count_only=1
    BURROW_HOME="$home" BURROW_COUNT="$count_only" python3 - <<'PY'
import socket, json, os, sys
home = os.environ["BURROW_HOME"]
try:
    tok = open(os.path.join(home, "daemon.token")).read().strip()
    s = socket.socket(socket.AF_UNIX); s.connect(os.path.join(home, "daemon.sock"))
    f = s.makefile("rwb")
    def send(o): f.write((json.dumps(o)+"\n").encode()); f.flush(); return json.loads(f.readline())
    send({"id": 1, "cmd": "Auth", "token": tok})
    sess = send({"id": 2, "cmd": "ListSessions"}).get("sessions", [])
except Exception as e:
    print(f"burrow sessions: cannot reach daemon ({e})", file=sys.stderr); sys.exit(1)
alive = [x for x in sess if x.get("alive")]
if os.environ.get("BURROW_COUNT") == "1":
    print(len(alive)); sys.exit(0)
print(f"{len(alive)} live session(s):")
for x in alive:
    print(f"  pty {x.get('pty_id'):<5} {x.get('cwd','')}")
PY
    exit $?
    ;;

  *)
    echo "burrow: unknown command '$sub' (use spawn|collect|wait|sessions|status|hook|notify)" >&2
    exit 1
    ;;
esac
